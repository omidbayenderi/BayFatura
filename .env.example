# ===== BAYFATURA ENVIRONMENT VARIABLES =====
# Copy this file to .env and fill in your values.
# Never commit .env to git!

# ===== STRIPE =====
VITE_SUCCESS_URL=http://localhost:5173/success
VITE_CANCEL_URL=http://localhost:5173/

# ===== FIREBASE =====
# Get these from: Firebase Console > Project Settings > General > Your Apps > Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ===== RESEND EMAIL =====
VITE_FROM_EMAIL=noreply@yourdomain.com

# ===== SENTRY =====
# Get DSN from: sentry.io → Projects → BayFatura → Client Keys
# Leave empty to disable Sentry (e.g., in dev)
VITE_SENTRY_DSN=
VITE_APP_ENV=development

# ===== PREVIEW/STAGING =====
# For preview builds, copy .env.preview to .env.preview.local
# and fill in the staging Firebase project credentials.
# Preview build command: npm run build:preview
